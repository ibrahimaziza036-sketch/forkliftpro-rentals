# ======================================
# ForkliftPro Rentals — Environment Variables
# ======================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# Google Analytics 4
# Get your Measurement ID from: https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification (meta tag value)
# Get from: https://search.google.com/search-console
NEXT_PUBLIC_GSC_VERIFICATION=

# Resend Email API
# Sign up free at: https://resend.com (100 emails/day free)
RESEND_API_KEY=
CONTACT_EMAIL_TO=info@forkliftprorentals.com

# Cloudflare Turnstile CAPTCHA
# Get keys from: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis (for serverless rate limiting)
# Sign up free at: https://upstash.com (10,000 requests/day free)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
